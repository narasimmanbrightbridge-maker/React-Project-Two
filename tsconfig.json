{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.bin/tsconfig.app.tsbuildinfo",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Relaxed Linting - Fixes your Vercel errors */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    
    /* JavaScript Support - Fixes the .jsx import errors */
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true
  },
  "include": ["src"]
}